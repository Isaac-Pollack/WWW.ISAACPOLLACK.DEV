---
const { title, url, description, image, langs } = Astro.props;
---

<a href={url} aria-label={`link to ${title}`}>
	<div
		class="flex flex-col h-full p-4 flex-wrap text-gray-700 rounded-lg shadow-xl bg-gray-200 dark:bg-gray-800 dark:text-gray-300 hover:bg-[#f5f6f7] dark:hover:bg-gray-700 hover:-translate-y-1 duration-300">
		<img class="object-fill h-48 w-full rounded-full" />
		<h3 class="text-2xl text-center font-semibold p-2">{title}</h3>
		<p class="p-2">{description}</p>
		<p class="p-2">{langs}</p>
	</div>
</a>
